<div id="beta" class="beta-form-card">
  <% if notice.present? %>
    <div class="form-success" role="status"><%= notice %></div>
  <% end %>

  <% if beta_signup.errors.any? %>
    <div class="form-errors" role="alert">
      <strong>Please check the signup form:</strong>
      <ul>
        <% beta_signup.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: beta_signup, url: beta_signups_path, local: true, class: "beta-form" do |form| %>
    <div class="form-grid">
      <div class="field field-required">
        <%= form.label :email, "Work email" %>
        <%= form.email_field :email, required: true, autocomplete: "email", placeholder: "you@company.com" %>
      </div>

      <div class="field">
        <%= form.label :name, "Name" %>
        <%= form.text_field :name, autocomplete: "name", placeholder: "Your name" %>
      </div>

      <div class="field">
        <%= form.label :company, "Company" %>
        <%= form.text_field :company, autocomplete: "organization", placeholder: "Company name" %>
      </div>

      <div class="field">
        <%= form.label :job_title, "Role" %>
        <%= form.text_field :job_title, placeholder: "Owner, designer, estimator..." %>
      </div>

      <div class="field">
        <%= form.label :team_size, "Team size" %>
        <%= form.select :team_size,
                        [["Just me", "solo"], ["2–5", "2-5"], ["6–15", "6-15"], ["16+", "16+"]],
                        { include_blank: "Select one" } %>
      </div>

      <label class="checkbox-field">
        <%= form.check_box :ipads_in_field %>
        <span>We use iPads in the field</span>
      </label>
    </div>

    <div class="field">
      <%= form.label :current_workflow, "Current walkthrough workflow" %>
      <%= form.text_area :current_workflow, rows: 3, placeholder: "Apple Notes, CompanyCam, spreadsheets, CRM notes..." %>
    </div>

    <div class="form-footer">
      <%= form.button "Join the beta", class: "button button-primary" %>
      <p>No spam. We’ll use this only for RoomScope beta follow-up.</p>
    </div>
  <% end %>
</div>
